{
  "name": "@greypan/js-kit",
  "version": "1.6.4",
  "description": "JavaScript utility functions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js"
    },
    "./go": {
      "types": "./dist/paradigm/go.d.ts",
      "import": "./dist/paradigm/go.js"
    },
    "./rust": {
      "types": "./dist/paradigm/rust.d.ts",
      "import": "./dist/paradigm/rust.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp build",
    "test": "vp test run",
    "dev": "vp build --watch"
  },
  "dependencies": {
    "remeda": "catalog:",
    "nanoid": "catalog:"
  },
  "devDependencies": {
    "@greypan/tsconfig": "workspace:*",
    "vite-plugin-dts": "catalog:"
  },
  "browserslist": [
    "defaults"
  ]
}
