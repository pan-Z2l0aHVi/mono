{
  "name": "@greypan/js-kit",
  "version": "1.0.0",
  "description": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js"
    },
    "./go": {
      "types": "./dist/paradigm/go.d.ts",
      "import": "./dist/paradigm/go.js"
    },
    "./rust": {
      "types": "./dist/paradigm/rust.d.ts",
      "import": "./dist/paradigm/rust.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vp build",
    "deploy": "npm publish",
    "preview": "vp preview",
    "test": "vp test run",
    "type-check": "vue-tsc --build",
    "dev": "vp build --watch"
  },
  "dependencies": {},
  "devDependencies": {
    "vite": "catalog:",
    "vite-plus": "catalog:"
  },
  "browserslist": [
    "defaults"
  ]
}
