{
  "name": "@greypan/vite-plugin-full-reload",
  "version": "1.2.2",
  "description": "Vite HMR plugin for full page reload",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vue-tsc --build && vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "type-check": "vue-tsc --build",
    "dev": "vp build --watch"
  },
  "dependencies": {
    "@greypan/js-kit": "workspace:*",
    "unplugin": "catalog:"
  },
  "browserslist": [
    "defaults"
  ]
}
