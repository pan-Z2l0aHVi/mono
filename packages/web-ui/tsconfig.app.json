{
  "extends": "@greypan/tsconfig/dom.json",
  "exclude": ["src/**/__tests__/*"],
  "include": ["src/**/*"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "types": ["vite/client"],
    // Lit 需要
    "experimentalDecorators": true,
    "useDefineForClassFields": false
  }
}
