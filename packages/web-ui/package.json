{
  "name": "@greypan/web-ui",
  "version": "1.2.3",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/index.js",
    "./dist/components/*/index.js",
    "./dist/**/*.css"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./types/*": "./dist/types/*.d.ts",
    "./vue": {
      "types": "./dist/types/vue.d.ts"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vue-tsc --build && vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "type-check": "vue-tsc --build",
    "dev": "vp build --watch"
  },
  "dependencies": {
    "@greypan/browser-kit": "workspace:*",
    "@greypan/js-kit": "workspace:*",
    "iconify-icon": "catalog:",
    "lit": "catalog:"
  },
  "devDependencies": {
    "react": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "react": ">=16",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "browserslist": [
    "defaults"
  ],
  "description": "Lit-based web components for React, Vue, and vanilla JS"
}
