{
  "name": "@greypan/web-ui",
  "version": "1.4.2",
  "description": "Lit-based web components for React, Vue, and vanilla JS",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": [
    "./dist/components/*/index.js",
    "./dist/**/*.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/components/index.d.ts",
      "import": "./dist/components/index.js"
    },
    "./components/*": {
      "types": "./dist/components/*/index.d.ts",
      "import": "./dist/components/*/index.js"
    },
    "./icons": {
      "types": "./dist/icons/index.d.ts",
      "import": "./dist/icons/index.js"
    },
    "./icons/*": {
      "types": "./dist/icons/*.d.ts",
      "import": "./dist/icons/*.js"
    },
    "./types/*": "./dist/types/*.d.ts",
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp build",
    "test": "vp test run",
    "dev": "vp build --watch",
    "generate-icons": "node --experimental-strip-types scripts/generate-icons.ts"
  },
  "dependencies": {
    "@greypan/browser-kit": "workspace:*",
    "@greypan/js-kit": "workspace:*"
  },
  "devDependencies": {
    "@greypan/tsconfig": "workspace:*",
    "@iconify-json/lucide": "catalog:",
    "@iconify-json/jam": "catalog:",
    "@iconify/types": "catalog:",
    "@types/react": "catalog:",
    "lit": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "@types/react": ">=16",
    "lit": "catalog:",
    "vue": ">=3"
  },
  "peerDependenciesMeta": {
    "@types/react": {
      "optional": true
    },
    "vue": {
      "optional": true
    }
  },
  "browserslist": [
    "defaults"
  ]
}
