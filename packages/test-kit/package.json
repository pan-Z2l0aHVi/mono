{
  "name": "@greypan/test-kit",
  "version": "0.2.1",
  "description": "Test infrastructure plugins for Vitest browser mode + MSW",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
