{
  "name": "@greypan/browser-kit",
  "version": "1.1.0",
  "description": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vp build",
    "preview": "vp preview",
    "test": "vp test run",
    "type-check": "vue-tsc --build",
    "dev": "vp build --watch"
  },
  "dependencies": {
    "@greypan/js-kit": "workspace:*",
    "idb-keyval": "^6.2.6",
    "nanoid": "catalog:",
    "remeda": "catalog:"
  },
  "browserslist": [
    "defaults"
  ]
}
