{
  "name": "@greypan/browser-kit",
  "version": "1.7.0",
  "description": "Browser utility functions",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*/index.d.ts",
      "import": "./dist/*/index.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vue-tsc --build && vp build",
    "test": "vp test run",
    "dev": "vp build --watch"
  },
  "dependencies": {
    "@greypan/js-kit": "workspace:*",
    "copy-to-clipboard": "catalog:",
    "nanoid": "catalog:",
    "remeda": "catalog:"
  },
  "peerDependencies": {
    "msw": "catalog:"
  },
  "devDependencies": {
    "@greypan/test-kit": "workspace:*"
  },
  "browserslist": [
    "defaults"
  ]
}
