{
  "name": "@greypan/deps-reload",
  "version": "1.1.4",
  "description": "A Plugin that watches dist folder for changes and reloads the page",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    "./vite": {
      "types": "./dist/vite.d.mts",
      "import": "./dist/vite.mjs"
    },
    "./webpack": {
      "types": "./dist/webpack.d.mts",
      "import": "./dist/webpack.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "test": "vp test run",
    "dev": "vp pack --watch --clean=false"
  },
  "dependencies": {
    "@greypan/js-kit": "workspace:*",
    "unplugin": "catalog:"
  },
  "devDependencies": {
    "@greypan/tsconfig": "workspace:*"
  },
  "peerDependencies": {
    "vite": "catalog:",
    "webpack": "catalog:"
  },
  "peerDependenciesMeta": {
    "vite": {
      "optional": true
    },
    "webpack": {
      "optional": true
    }
  },
  "browserslist": [
    "defaults"
  ]
}
