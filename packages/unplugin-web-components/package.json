{
  "name": "@greypan/unplugin-web-components",
  "version": "1.2.4",
  "description": "Unplugin for web components auto-import",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/pan-Z2l0aHVi/mono.git"
  },
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "build": "vp pack",
    "preview": "vp preview",
    "test": "vp test run",
    "dev": "vp pack --watch"
  },
  "dependencies": {
    "@greypan/js-kit": "workspace:*",
    "change-case": "catalog:",
    "unplugin": "catalog:"
  },
  "browserslist": [
    "defaults"
  ]
}
