{
  "extends": "./dom.json",
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "erasableSyntaxOnly": true,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleDetection": "force",
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "useDefineForClassFields": true
  }
}
