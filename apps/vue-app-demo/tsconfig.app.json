{
  "extends": "@greypan/tsconfig/vue.json",
  "exclude": ["src/**/__tests__/*"],
  "include": ["src/**/*", "src/**/*.vue", "env.d.ts", "auto-imports.d.ts", "./typed-router.d.ts"],
  "compilerOptions": {
    "paths": {
      "@/*": ["./src/*"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo"
  }
}
