{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "@mono/mdgitai#build": {
      "dependsOn": ["^build"],
      "outputs": ["frontend/dist/**", "build/bin/**", "build/MyApp.app/**"]
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "deploy": {
      "dependsOn": ["build", "test"]
    },
    "test": {
      "dependsOn": ["^build"]
    }
  }
}
