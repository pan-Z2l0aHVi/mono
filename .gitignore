# ==========================================
# 核心依赖与系统文件 (Core & System)
# ==========================================
node_modules/
.DS_Store
Thumbs.db
*.log
logs/
*.gz
*.pfx
*.certificate

# 常见的 debug 日志（支持所有主流包管理器）
*-debug.log*
*-error.log*
.pnpm-debug.log*

# ==========================================
# 工具链缓存与产物 (Build Tools & Monorepo)
# ==========================================
.turbo/
.cache/
.temp/
.storage/

# 构建输出目录
dist/
dist-ssr/
lib/
esm/
out/
site/
build/
.next/
.nuxt/
.output/

# 环境变量
.env
.env.*
!.env.example

# ==========================================
# TypeScript & 编译器 (Compilers)
# ==========================================
*.tsbuildinfo
*.metadata.json

# ==========================================
# 测试与代码质量 (Testing & Linting)
# ==========================================
coverage/
__snapshots__/
*.received.*
.eslintcache
.stylelintcache
.cspellcache
.prettiercache
.husky/_/

# 可视化分析报告
stats.html
report.html

# ==========================================
# 编辑器与 IDE (Editors)
# ==========================================
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# 针对 VSCode/Zed：忽略所有配置，但保留共享的工程配置
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

.zed/*
!.zed/settings.json

.tanstack/*

# ==========================================
# 本地开发私有文件 (Local Private)
# ==========================================
*.local
# Cloudflare Workers 等工具使用
.dev.vars

# ==========================================
# 工具链自动生成 (Auto Generated)
# ==========================================
wailsjs/
typed-router.d.ts
auto-imports.d.ts
.eslintrc-auto-import.js
routeTree.gen.ts
package.json.md5
