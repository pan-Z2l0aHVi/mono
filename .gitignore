# ==========================================
# 核心依赖与系统文件 (Core & System)
# ==========================================
node_modules/
.DS_Store
Thumbs.db
*.log
logs/
*.gz
*.pfx
*.certificate
*.pem
*.key

# 常见的 debug 日志（支持所有主流包管理器）
*-debug.log*
*-error.log*
.pnpm-debug.log*

# ==========================================
# 工具链缓存与产物 (Build Tools & Monorepo)
# ==========================================
.turbo/
.cache/
.temp/
.storage/
tmp/
temp/

# 构建输出目录
dist/
dist-ssr/
lib/
esm/
out/
site/
build/
.next/
.nuxt/
.output/
dev-dist/

# Monorepo 根目录 src/ 不应存在，偶尔被外部工具误创建，忽略掉
/src

# 环境变量
.env
.env.*
!.env.example

# ==========================================
# TypeScript & 编译器 (Compilers)
# ==========================================
*.tsbuildinfo
*.metadata.json

# ==========================================
# 测试与代码质量 (Testing & Linting)
# ==========================================
coverage/
__snapshots__/
*.received.*
.eslintcache
.stylelintcache
.cspellcache
.prettiercache
.husky/_/

# 可视化分析报告
stats.html
report.html

# ==========================================
# 编辑器 (Editors)
# ==========================================
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# VSCode
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
!.vscode/launch.json
!.vscode/tasks.json

# Zed
.zed/*
!.zed/settings.json

# Cursor / Windsurf
.cursor/
.windsurf/

# ==========================================
# AI Agent 工具 (AI Coding Agents)
# ==========================================
# 策略同 .vscode / .zed：忽略全部，显式放行团队共享配置

# Claude Code — 忽略本地缓存，保留共享配置和指令
.claude/*
!.claude/settings.json
!.claude/commands/
!.claude/skills
# CLAUDE.md 放项目根目录，不在 .claude 内

# OpenCode
.opencode/*
!.opencode/rules/
!.opencode/settings.json

# MimoCode
.mimocode/*
!.mimocode/rules/
!.mimocode/settings.json
!.mimocode/skills

# Cursor
.cursor/*
!.cursor/rules/

# Windsurf
.windsurf/*
!.windsurf/rules/

# Continue.dev
.continue/*
!.continue/config.json

# Aider
.aider*/

# ==========================================
# 框架自动生成 (Framework Generated)
# ==========================================
.tanstack/*

# ==========================================
# 本地开发私有文件 (Local Private)
# ==========================================
*.local
# Cloudflare Workers 等
.dev.vars

# ==========================================
# 工具链自动生成 (Auto Generated)
# ==========================================
wailsjs/
typed-router.d.ts
auto-imports.d.ts
.eslintrc-auto-import.js
routeTree.gen.ts
package.json.md5
